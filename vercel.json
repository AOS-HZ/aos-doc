{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "docs/.vuepress/dist",
  "rewrites": [
    {
      "source": "/doc/",
      "destination": "/"
    },
    {
      "source": "/doc",
      "destination": "/"
    },
    {
      "source": "/doc/aos-desktop/",
      "destination": "/aos-desktop/"
    },
    {
      "source": "/doc/:path*",
      "destination": "/:path*"
    }
  ]
}
